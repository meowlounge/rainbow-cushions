{
  "schemaVersion": 1,
  "id": "rainbow-cushions",
  "version": "${version}",
  "name": "Rainbow Cushion",
  "description": "Makes cushions named jeb_ cycle through rainbow colors like jeb_ sheep.",
  "authors": [
    "cow"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/rainbowcushion",
    "sources": "https://github.com/meowlounge/rainbow-cushions",
    "issues": "https://github.com/meowlounge/rainbow-cushions/issues"
  },
  "license": "MIT",
  "icon": "assets/rainbow-cushions/icon.png",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "dev.prodbyeagle.rainbowCushions.client.RainbowCushionsDataGenerator"
    ],
    "client": [
      "dev.prodbyeagle.rainbowCushions.client.RainbowCushionsClient"
    ],
    "main": [
      "dev.prodbyeagle.rainbowCushions.RainbowCushions"
    ]
  },
  "mixins": [
    "rainbow-cushions.mixins.json",
    {
      "config": "rainbow-cushions.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${mod_minecraft_version}"
  }
}
